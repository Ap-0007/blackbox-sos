# --- Mobile app (prefix EXPO_PUBLIC_ to expose to client) ---
EXPO_PUBLIC_GROQ_API_KEY=gsk_...          # get free key at console.groq.com
EXPO_PUBLIC_FIREBASE_API_KEY=AIza...
EXPO_PUBLIC_FIREBASE_PROJECT=your-project-id
EXPO_PUBLIC_BACKEND_URL=http://192.168.x.x:3001   # your LAN IP for device testing

# --- Backend / Vercel only (never expose to client) ---
GROQ_API_KEY=gsk_...                      # same key, server-side for /api/classify
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1415...
PORT=3001
